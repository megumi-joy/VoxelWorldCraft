; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="VoxelWorldCraft"
config/version="0.3.0"
run/main_scene="res://Scenes/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

NetworkManager="*res://Scripts/Autoload/NetworkManager.gd"
ItemDatabase="*res://Scripts/Autoload/ItemDatabase.gd"
CodexDatabase="*res://Scripts/Autoload/CodexDatabase.gd"
SaveSystem="*res://Scripts/Autoload/SaveSystem.gd"
AutoTester="*res://Scripts/Testing/AutoTester.gd"
HudSettings="*res://Scripts/Autoload/HudSettings.gd"
GraphicsSettings="*res://Scripts/Autoload/GraphicsSettings.gd"
ActionLog="*res://Scripts/Autoload/ActionLog.gd"
SoundCaptions="*res://Scripts/Autoload/SoundCaptions.gd"
Telemetry="*res://Scripts/Autoload/Telemetry.gd"
WeatherSystem="*res://Scripts/Autoload/WeatherSystem.gd"
FoliageRenderer="*res://Scripts/Autoload/FoliageRenderer.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
; canvas_items stretch keeps every Control's pixel sizes proportional to the
; actual render resolution instead of literal 1:1 pixels. Without this, a
; HUD authored against the 1280x720 base (e.g. the movie-maker recipe's
; default 480x270 capture res) renders at full fixed-pixel size against a
; much smaller viewport -- the panel/hotbar that reads as a tasteful corner
; overlay at 1280x720 balloons to ~2.5x the screen fraction at 480x270,
; which is what made the HUD look oversized in the v0.2.0 showcase capture.
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
