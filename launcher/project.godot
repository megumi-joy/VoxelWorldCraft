; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="VoxelWorldCraft Launcher"
config/version="0.1.0"
run/main_scene="res://Scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=480
window/size/viewport_height=640
window/size/resizable=false
; canvas_items keeps the chunky UI crisp and proportional if the OS ever
; forces a different window size (e.g. a compositor override) -- same
; reasoning as the main game project's window/stretch settings.
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

; This is a small always-on-top-ish UI window, not the 3D voxel game --
; the Mobile renderer is plenty and keeps the launcher lightweight on
; whatever GPU (or software/llvmpipe fallback) happens to be available,
; which matters since the launcher is meant to be the very first thing
; that runs, before we know anything about the target machine.
renderer/rendering_method="mobile"
